{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yamani/devrunway/setup/stack.schema.json",
  "title": "devrunway stack.json",
  "description": "Stack configuration generated by /setup. Describes every technology layer chosen for this project.",
  "type": "object",
  "required": [
    "devrunway",
    "source-control",
    "ci",
    "package-manager",
    "code-quality",
    "frontend",
    "css",
    "ui-components",
    "state",
    "i18n",
    "component-docs",
    "design",
    "backend",
    "api-style",
    "validation",
    "api-docs",
    "cloud",
    "container",
    "database",
    "auth",
    "cache-queue",
    "storage",
    "secrets",
    "feature-flags",
    "logging-framework",
    "logging-provider",
    "error-monitoring",
    "realtime",
    "search",
    "payment",
    "email",
    "testing-unit",
    "testing-e2e",
    "testing-api",
    "mocking",
    "project-management"
  ],
  "additionalProperties": false,
  "properties": {
    "devrunway": {
      "description": "Schema version — always \"1.0\".",
      "type": "string",
      "const": "1.0"
    },
    "source-control": {
      "description": "Git provider (Q1).",
      "type": "string",
      "enum": ["github", "gitlab", "bitbucket", "azure-devops", "none"]
    },
    "ci": {
      "description": "CI/CD platform (Q2).",
      "type": "string",
      "enum": ["github-actions", "gitlab-ci", "circleci", "azure-pipelines", "none"]
    },
    "package-manager": {
      "description": "Node package manager (Q3).",
      "type": "string",
      "enum": ["npm", "pnpm", "yarn", "bun"]
    },
    "code-quality": {
      "description": "Code quality / security scanning tool (Q4).",
      "type": "string",
      "enum": ["github-security", "sonarqube", "snyk", "none"]
    },
    "frontend": {
      "description": "Frontend framework (Q5).",
      "type": "string",
      "enum": ["react", "vue", "angular", "nextjs", "none"]
    },
    "css": {
      "description": "CSS framework or styling approach (Q6).",
      "type": "string",
      "enum": ["tailwind", "styled-components", "css-modules", "bootstrap", "none"]
    },
    "ui-components": {
      "description": "UI component library (Q7).",
      "type": "string",
      "enum": ["shadcn", "mui", "ant-design", "chakra", "none"]
    },
    "state": {
      "description": "Client-side state management library (Q8).",
      "type": "string",
      "enum": ["zustand", "redux-toolkit", "jotai", "pinia", "none"]
    },
    "i18n": {
      "description": "Internationalisation library (Q9).",
      "type": "string",
      "enum": ["react-i18next", "lingui", "vue-i18n", "none"]
    },
    "component-docs": {
      "description": "Component documentation / visual testing tool (Q10).",
      "type": "string",
      "enum": ["storybook", "ladle", "none"]
    },
    "design": {
      "description": "Design tool used by the team (Q11).",
      "type": "string",
      "enum": ["figma", "sketch", "adobe-xd", "none"]
    },
    "backend": {
      "description": "Backend runtime and framework (Q12).",
      "type": "string",
      "enum": ["node-express", "python-fastapi", "python-django", "dotnet", "none"]
    },
    "api-style": {
      "description": "API paradigm (Q13).",
      "type": "string",
      "enum": ["rest", "graphql", "trpc", "grpc", "none"]
    },
    "validation": {
      "description": "Schema validation library (Q14).",
      "type": "string",
      "enum": ["zod", "yup", "valibot", "joi", "none"]
    },
    "api-docs": {
      "description": "API documentation generator (Q15).",
      "type": "string",
      "enum": ["swagger-express", "openapi-fastapi", "none"]
    },
    "cloud": {
      "description": "Cloud provider (Q16).",
      "type": "string",
      "enum": ["aws", "gcp", "azure", "none"]
    },
    "container": {
      "description": "Container or deployment target (Q17).",
      "type": "string",
      "enum": ["serverless", "docker", "kubernetes", "vercel", "railway", "none"]
    },
    "database": {
      "description": "Primary database and ORM (Q18).",
      "type": "string",
      "enum": ["postgres-prisma", "mongodb", "dynamodb", "sqlalchemy", "none"]
    },
    "auth": {
      "description": "Authentication provider (Q19).",
      "type": "string",
      "enum": ["cognito", "firebase", "auth0", "azure-ad", "none"]
    },
    "cache-queue": {
      "description": "Caching or message-queue technology (Q20).",
      "type": "string",
      "enum": ["redis", "sqs", "bullmq", "rabbitmq", "none"]
    },
    "storage": {
      "description": "Object / file storage provider (Q21).",
      "type": "string",
      "enum": ["s3", "gcs", "cloudinary", "uploadthing", "none"]
    },
    "secrets": {
      "description": "Secrets management strategy (Q22).",
      "type": "string",
      "enum": ["aws-secrets-manager", "doppler", "vault", "env-only"]
    },
    "feature-flags": {
      "description": "Feature flag service (Q23).",
      "type": "string",
      "enum": ["aws-appconfig", "launchdarkly", "posthog", "flagsmith", "none"]
    },
    "logging-framework": {
      "description": "Structured logging library (Q24).",
      "type": "string",
      "enum": ["pino", "winston", "morgan", "none"]
    },
    "logging-provider": {
      "description": "Log aggregation / observability destination (Q25).",
      "type": "string",
      "enum": ["cloudwatch", "datadog", "splunk", "grafana-loki", "newrelic", "none"]
    },
    "error-monitoring": {
      "description": "Error tracking and APM service (Q26).",
      "type": "string",
      "enum": ["sentry", "datadog-apm", "bugsnag", "none"]
    },
    "realtime": {
      "description": "Realtime / WebSocket service (Q27).",
      "type": "string",
      "enum": ["socketio", "pusher", "ably", "none"]
    },
    "search": {
      "description": "Full-text search service (Q28).",
      "type": "string",
      "enum": ["algolia", "typesense", "elasticsearch", "none"]
    },
    "payment": {
      "description": "Payment processing provider (Q29).",
      "type": "string",
      "enum": ["stripe", "paypal", "braintree", "none"]
    },
    "email": {
      "description": "Transactional email provider (Q30).",
      "type": "string",
      "enum": ["resend", "sendgrid", "ses", "none"]
    },
    "testing-unit": {
      "description": "Unit and integration test runner (Q31).",
      "type": "string",
      "enum": ["vitest", "jest", "pytest", "none"]
    },
    "testing-e2e": {
      "description": "End-to-end test framework (Q32).",
      "type": "string",
      "enum": ["playwright", "cypress", "selenium", "webdriverio", "none"]
    },
    "testing-api": {
      "description": "API testing tool (Q33).",
      "type": "string",
      "enum": ["bruno", "postman", "insomnia", "none"]
    },
    "mocking": {
      "description": "API mocking library for tests (Q34).",
      "type": "string",
      "enum": ["msw", "mirage", "json-server", "none"]
    },
    "project-management": {
      "description": "Project / issue tracking tool (Q35).",
      "type": "string",
      "enum": ["github", "jira", "linear", "huly", "none"]
    }
  }
}
